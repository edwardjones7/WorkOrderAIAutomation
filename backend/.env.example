# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=your-service-role-key   # server-side only

# ── AI extraction ─────────────────────────────────────────────────────────────
# Provider auto-selects: Anthropic if ANTHROPIC_API_KEY is set, else the free
# Gemini path if GEMINI_API_KEY is set. Force one with EXTRACTOR_PROVIDER if you like.
# EXTRACTOR_PROVIDER=anthropic        # or: gemini  (leave unset for auto)

# Claude (paid)
ANTHROPIC_API_KEY=sk-ant-...
EXTRACTOR_MODEL=claude-sonnet-5
EXTRACTOR_MODEL_CHEAP=claude-haiku-4-5-20251001

# Google Gemini (free — get a key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# ── Gmail (OAuth installed-app creds; run scripts/gmail_auth.py to mint token) ─
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...
# Comma-separated substrings; empty = accept any sender
WO_SENDER_ALLOWLIST=
GMAIL_POLL_SECONDS=120

# ── Notifications / dashboard ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
DASHBOARD_URL=http://localhost:3000

# ── AppFolio browser automation (Phase 4) ─────────────────────────────────────
APPFOLIO_LOGIN_URL=https://YOURCOMPANY.appfolio.com/
APPFOLIO_USERNAME=
APPFOLIO_PASSWORD=
APPFOLIO_STOP_BEFORE_SUBMIT=true
